# ============================
#        IP Lookup
# ============================
def ip_lookup():
    ip = input("Enter IP: ")
    try:
        r = requests.get(f"http://ip-api.com/json/{ip}")
        data = r.json()

        print(Fore.RED + "\n===== RESULT =====")
        print("IP:", data["query"])
        print("Country:", data["country"])
        print("City:", data["city"])
        print("ISP:", data["isp"])
        print("Timezone:", data["timezone"])
        print(Fore.RED + "==================\n")

    except:
        print("Error while searching IP.")


# ============================
#        GeoIP+
# ============================
def geoip_plus():
    ip = input("Enter IP: ")
    try:
        r = requests.get(f"http://ip-api.com/json/{ip}?fields=66846719")
        data = r.json()

        print(Fore.RED + "\n===== GEOIP+ =====")
        for key, value in data.items():
            print(f"{key}: {value}")
        print(Fore.RED + "==================\n")

    except:
        print("Error while searching GeoIP.")


# ============================
#        Host Lookup
# ============================
def host_lookup():
    site = input("Enter website (ex: google.com): ")

    try:
        ip = socket.gethostbyname(site)
        r = requests.get(f"http://ip-api.com/json/{ip}?fields=66846719")
        data = r.json()

        print(Fore.RED + "\n===== HOST LOOKUP =====")
        print("Website:", site)
        print("IP:", ip)
        print("Country:", data.get("country"))
        print("Region:", data.get("regionName"))
        print("City:", data.get("city"))
        print("ISP:", data.get("isp"))
        print("ORG:", data.get("org"))
        print("AS:", data.get("as"))
        print("Lat:", data.get("lat"))
        print("Lon:", data.get("lon"))
        print(Fore.RED + "=======================\n")

    except:
        print("Error while resolving host.")


# ============================
#        Webhook Sender
# ============================
def webhook_sender():
    url = input("Webhook URL: ")
    message = input("Message: ")

    data = {"content": message}

    try:
        requests.post(url, json=data)
        print("Message sent!")
    except:
        print("Error sending webhook.")


# ============================
#        Ping Tool
# ============================
def ping_tool():
    host = input("IP or website: ")
    os.system(f"ping {host}")


# ============================
#        Username Checker
# ============================
def username_checker():
    username = input("Username: ")

    sites = {
        "GitHub": f"https://github.com/{username}",
        "Reddit": f"https://www.reddit.com/user/{username}",
        "TikTok": f"https://www.tiktok.com/@{username}"
    }

    for site, url in sites.items():
        r = requests.get(url)
        if r.status_code == 200:
            print(Fore.RED + f"{site}: FOUND -> {url}")
        else:
            print(f"{site}: Not found")


